	Godhead: {
		DisplayName: Божественность
		Tooltip:
			'''
			Ваша бомба будет иметь ауру, которая будет продолжать наносить вред врагам внутри ауры.
			При закрытии видимости аксессуаров нельзя увидеть ауру, но это нормально наносит вред
			Аура игнорирует непобедимый кадр.
			'''
	}

	VoidEcho: {
		DisplayName: Символ теократии
		Tooltip:
			'''
			Зовите пушку.
			Отключение мыши одновременно запускает пустой лазер.
			« Даже часть пустоты обладает силой уничтожить все.
			'''
	}

	FriendBox: {
		DisplayName: Коробка друзей
		Tooltip:
			'''
			Вызовите пару запутавшихся близнецов и скопируйте свою занавеску.
			Скопировать занавеску и нанести 100 - процентный урон оригинальному оружию
			Все причиненные повреждения были сокращены до 1 / 5 от первоначального
			Каждая пара запутанных близнецов потребляет 4 строки вызова
			'''
	}

