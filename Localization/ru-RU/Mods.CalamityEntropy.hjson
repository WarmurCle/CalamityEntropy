	BookMarkRoyal: {
		DisplayName: Королевские закладки
		Tooltip:
			'''
			Создано три коронных камня.
			Руби выстрелит в врага энергетическими бомбами.
			Изумруд врезается в врага.
			Сапфир будет усиливать близлежащих игроков, увеличивая их восстановление жизни, снижение травматизма, травмы и скорость атаки
			'''
	}

	EntropyModeToggle: {
		DisplayName: Ядро энтропии
		Tooltip:
			'''
			Увеличить сложность, меньше жизни, травм и жизнеспособности.
			Boss получает динамическое уменьшение травматизма и максимальное ограничение травматизма при однократной травме, процент уменьшает жизнь, броню, скорость удара может достигать до 50%, увеличение травматизма уменьшается, уменьшается часть маневра
			Некоторые Boss получили изменения
			Проповедь получает специальное добавление, которое можно открыть.
			[c/ff0000: Примечание: Эта модель не входит в официальный рекомендуемый процесс энтропии бедствия, который никогда не учитывается в процессе и балансировке энтропии бедствия]
			[c/ff0000: Если вы считаете, что этот модуль нарушает превосходное равновесие оригинального процесса бедствия, то включение этого режима может привести к тому, что вы считаете равновесием]
			Используйте правую кнопку, чтобы включить только функцию динамического уменьшения повреждений boss
			'''
	}

	BookMarkPerfection: {
		DisplayName: Полный экзамен.
		Tooltip:
			'''
			Увеличить вероятность запуска всех других закладок
