ModNameOverride: Calamity Entropy

Items: {
	VoidBlade: {
		DisplayName: Пустой клинок
		Tooltip: Быстрый, непрерывный удар.
	}

	Weapons: {
		Rogue: {
			Revelation: {
				DisplayName: Апокалипсис
				Tooltip:
					'''
					Бросьте серп, который вращается, и оставьте отследить застрявшую занавеску.
					Вместо "скрытой атаки" следует размахивать серпом и стрелять тремя выстрелами из автоматического оружия слежения.
					'''
			}

			Silence: {
				DisplayName: Молчание
				Tooltip:
					'''
					Бросьте фрисби, который тянет себя к врагу с помощью пустой цепи.
					Скрытая атака может нависать над врагом и наносить вред.
					'''
			}

			ShadewindLance: {
				DisplayName: Небеса падают
				Tooltip:
					'''
					Выбросить копье, которое работает на пустоте.
					Скрытая атака будет иметь более высокие повреждения и скорость, и она будет проникать бесконечно.
					'''
			}

			Aquashard: {
				DisplayName: Голубые волны
				Tooltip:
					'''
					Бросая копье, которое попадет в врага, он разобьется, чтобы отследить осколки кристаллов.
					Скрытая атака будет проникать и оставлять осколки призмы во время полета копья, в то время как при ударе будет разделено больше фрагментов призмы
					'''
			}

			SpearOfRadiance: {
				DisplayName: Оружие Святого Света
				Tooltip:
					'''
					Бросьте священный копье.
					Скрытая атака получает больше проникновения, и при первом ударе появляется крестовый свет.
					'''
			}

			AbyssalPiercer: {
				DisplayName: Проникновение в море
				Tooltip:
					'''
					Бросил копье, которое отследило поток.
					Скрытая атака создаст водоворот бездны после первого удара и протянет шипы рифа.
					'''
			}

			AzureOfFirmament: {
				DisplayName: Небо ясное
				Tooltip:
					'''
					Бросил копье в небо.
					Скрытая атака рассеивает перья одновременно.
					Когда копье попадает в цель, перья летят к цели.
					'''
			}

			ArbitratorII: {
				DisplayName: Арбитр II
				Tooltip:
					'''
					Бросьте копье, которое взорвется.
					Скрытая атака может проникнуть в цель и через секунду произвести еще больший взрыв.
					'''
			}

			Voidseeker: {
				DisplayName: Обыкновенный серп
				Tooltip:
					'''
					Серп
					Скрытая атака передается на курсор и наносит еще больший удар сверху вниз.
					Получите короткое время непобедимости после передачи.
					'''
			}

			TheBeginingAndTheEnd: {
				DisplayName: Начало и конец
				Tooltip:
					'''
					Используйте правую и правую кнопки, чтобы стрелять разными ножами.
					В конце концов, это приводит к снижению видимости пропасти.
					Это приводит к уменьшению вреда.
					Когда другой летающий нож попадает в него, он очищает его и создает эхо - душу или дух тьмы в зависимости от того, сколько слоёв уменьшается.
					Душа эха будет продолжать атаковать монстров и исчезнет через несколько секунд.
					Душа тьмы летит к вам и лечит вас, временно увеличивая скорость атаки, травматизм и скорость атаки.
					Скрытая атака одновременно бросает два летающих ножа и преследует цель, поражая и разбрасывая две души.
					'''
			}

			AmethystFrisbee: {
				DisplayName: Фиолетовый диск
				Tooltip:
					'''
					Выбросить летающую тарелку, которая автоматически возвращается.
					Возвращающийся момент снова бросается, игнорируя гравитацию и вызывая высокочастотные повреждения.
					Скрытая атака ударит по врагу и нанесет урон близлежащим монстрам.
					'''
			}

			ProphecyFlyingKnife: {
				DisplayName: Пророческий нож
				Tooltip:
					'''
					Стреляйте ножами слежения.
					Скрытая атака. Вызовите шесть рун, чтобы напасть на монстра.
					'''
			}

			TheDeadCut: {
				DisplayName: Ложные трещины.
				Tooltip: Восстановление частичного скрытого значения после попадания
			}

			LunarPlank: {
				DisplayName: Фантомная плита
				Tooltip:
					'''
					Выброси и разбей своего врага.
					Скрытая атака может привести к повреждениям и высвободить несколько следов фантомных лучей.
					'''
			}

			AzafureSurgeRod: {
				DisplayName: пайка Асафора
				Tooltip:
					'''
					Попал в цель и через некоторое время ударил молнией по другим близлежащим целям.
					Скрытые атаки выбрасывают больше метательных предметов, зависают в воздухе и отслеживают близлежащие цели.
					'''
			}

			TlipocasScythe: {
				DisplayName: Серп Трипоки.
				Tooltip: ""
			}

			AzafureLightMachineGun: {
				DisplayName: Легкие пулеметы & lt; & lt; Асафор & gt; & gt;
				Tooltip:
					'''
					Лазер быстрого излучения
					После попадания лазера вы получите небольшое количество скрытых значений.
					Скрытая атака приведет к взрывающейся гранате, которая нанесет ущерб диапазону.
					'''
			}

			AzafureAirReaper: {
				DisplayName: Серп Асафора
				Tooltip:
					'''
					Выбросил серп, попал и прилип к цели, причинив несколько повреждений.
					Скрытая атака бросает серп, который продолжает преследовать цель после удара и резать ее взад и вперед.
					'''
			}

			CrystalSpike: {
				DisplayName: Магический шип
				Tooltip:
					'''
					Выбросить и привязать к цели, одна цель больше всего прилипает к корню [S]
					Скрытая атака отзовет все адгезивные шипы и выпустит кристаллическую бурю на курсор.
					Игнорируйте броню 4.
					'''
			}

			ScorchingChakram: {
				DisplayName: Зажженный клинок
				Tooltip:
					'''
					Выбросить горящее лезвие и взорвать его в отслеженные фрагменты плиты через некоторое время после полета
					Скрытая атака может заставить клинок выстрелить огненным шаром после остановки, а затем преследовать ближайшую цель и взорваться на большее количество осколков
					'''
			}

			EmberSpike: {
				DisplayName: Пепельный конус
				Tooltip:
					'''
					Выбросьте пепельный конус, который отскакивает от предмета до двух раз.
					Попав в монстра, он производит взрыв и врезается в него, и одна цель прилипает к корням максимум [S]
					Подводная атака отзовет все липкие конусы пепла и выпустит пепельный шторм в положение курсора, который может отскочить на блок до 5 раз.
					Подходящий удар создает отслеженные фрагменты плиты.
					Игнорировать броню 8.
					'''
			}
		}
	}

	PrisonOfPermafrost: {
		DisplayName: Холодные статуи на льду
		Tooltip:
			'''
			При использовании вызывается волшебство.
			Продолжайте стрелять ледяными шипами и конусами.
			[c/BEE2FF: "Я супер, лед! "]
			'''
	}

	Kinanition: {
		DisplayName: Слабые кровные родственники
		Tooltip:
			'''
			[c/ce97fa: левая кнопка запускает серию стрел молнии,]
			[c/ce97fa: Стрела молнии сохраняет первоначальный эффект боеприпаса и отслеживает его после попадания в цель]
			[c/0078b9: правая кнопка запускает отслеживающее копье молнии,]
			[c/0078b9: Вспышка молнии после поражения цели]
			'''
	}

	VoidRelics: {
		DisplayName: Священное письмо Пустоты
		Tooltip:
			'''
			Вызовите пустой знак, чтобы следовать курсору мыши
			Разбить врага в пределах досягаемости.
			Потребляйте все строки вызова, чем больше используется строка вызова, тем выше вред
			В то же время может существовать только один знак пустоты.
			Если при наличии метки используется левая кнопка, то следующий удар маркера будет еще больше и приведет к двойному повреждению и уменьшит значение метки смерти для близлежащих монстров.
			'''
	}

	AuricToilet: {
		DisplayName: Святой золотой унитаз
		Tooltip:
			'''
			Его использовали богоискатели.
			Теперь ты можешь сесть.
			"Дон уйдет"
			'''
	}

	LotteryBox: {
		DisplayName: Лотерейный ящик
		Tooltip:
