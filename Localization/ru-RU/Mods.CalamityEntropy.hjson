Configs: {
	Config: {
		VoidChargeBarX: {
			Label: Позиция полых зарядных полос X
			Tooltip: ""
		}

		Headers: {
			Misc: Разное
			Other: другие
			Compatibility: совместимость
		}

		DisplayName: Персональная конфигурация

		VoidChargeBarY: {
			Label: Позиция полых зарядных полос Y
			Tooltip: ""
		}

		ChainsawShakeScreen: {
			Label: Вибрационный эффект бензопилы
			Tooltip: ""
		}

		ItemAdditionalInfo: {
			Label: Дополнительная информация о предметах
			Tooltip: Показать дополнительную информацию о некоторых предметах, таких как бронепробивание, типы боеприпасов и т.д.
		}

		MariviumArmorSetOnlyProvideStealthBarWhenHoldingRogueWeapons: {
			Tooltip: Если вы играете в не воровские профессии и чувствуете, что скрытые полосы раздражают, откройте эту опцию.
			Label: Награды за полный профессиональный костюм предоставляются только при ношении оружия вора.
		}

		EntropyMeleeWeaponSoundVolume: {
			Label: Энтропия бедствия Оружие ближнего боя
			Tooltip: ""
		}

		ScreenWarpEffects: {
			Label: Экран спецэффектов
			Tooltip: Нарисовать ли деформированный экран и другие эффекты
		}

		EnablePixelEffect: {
			Label: Включить великолепные эффекты
			Tooltip: Нарисуйте ли вы определенные пиксельные / Metaball эффекты, выключите этот параметр, чтобы некоторые модули энтропии катастроф были скрыты от бомб / снарядов, не рекомендуется закрывать
		}

		EnableLoopingSound: {
			Label: Включить постоянные звуковые эффекты
			Tooltip: Включать ли определенные непрерывные звуковые эффекты, рекомендуется только в тех случаях, когда определенное оружие (перегрузка плавильных печей и т. Д.) вызывает флеш (что может быть вызвано невозможностью обнаружения динамиков)
		}

		EnableRetroLighting: {
			Label: Разрешить режим ретро - освещения и выключить волны
			Tooltip:
				'''
				Если вы все еще хотите использовать ретро - освещение или выключить режим качества волн, включите этот параметр.
				Закрытие этой опции отключит опцию [Включить великолепные спецэффекты], в которых UI не отображается должным образом из - за бага
				[c/FF0000: Предупреждение: Включение режима ретро - освещения или выключение волн может привести к тому, что некоторые спецэффекты, снаряды или NPC не будут должным образом нарисованы, что повлияет на игровой опыт]
				'''
		}
	}

	ServerConfig: {
		DisplayName: Настройка модулей
		Headers.Misc: Разное

		LoreSpecialEffect: {
			Label: Особые эффекты проповеди.
			Tooltip: Допускается добавление восхваляющей вещи, если энтропия не включена.
		}

		BramblecleaveAlwaysUnlockAllSkill: {
			Label: Отключить блокировку навыков Блудливого Фронта
			Tooltip: После включения все навыки Deep Front могут быть использованы в начале игры, а травмы зависят от повреждения панели оружия и подходят для игроков, которые хотят испытать эти навыки в начале игры.
		}

		LeastDamageSufferedBasedOnMaxHealth: {
			Label: По крайней мере, травмы.
			Tooltip: Исходя из вашего максимального значения жизни, каждый удар вычитает по крайней мере определенное значение жизни, по умолчанию 0, то есть не вступает в силу
		}

		ClearStealthWhenChangeEquipSet: {
			Label: Очистить скрытые полосы при переключении оборудования
			Tooltip: ""
		}

		ExtraItemsInStarterBag: {
			Label: Новые сумки Дополнительные предметы
			Tooltip: Новые сумки предоставят некоторые дополнительные полезные предметы (например, волшебное хранилище, волшебные палочки для лучшего опыта и т. Д.)
		}

		RogueAccessoriesProvide40Stealth: {
			Label: Грабители предлагают минимум 40 скрытых значений.
			Tooltip: Если вы носите какие - либо воровские украшения, у вас будет по крайней мере 20 скрытых значений.
		}
	}
}

vfb:
	'''
	Награды за костюм:
	+ 20 Проникновение брони
	Удар по цели накапливает энергию пустоты,
	Частичное смещение и скорость полёта в зависимости от количества энергии пустоты
	Нажмите клавишу вознаграждения, чтобы активировать энергию пустоты.
	Вызовите пустой фантом, чтобы помочь сражаться и летать бесконечно в течение 10 секунд.
	Тип повреждения зависит от оружия в руках.
	'''
helmvfc:
	'''
	- 25% Потребление магии
	Волшебная пуля поражает врага, уменьшает собственную магическую болезнь, уменьшает 0.5s
	'''
helmvfd:
	'''
	+ 24% Скорость атаки
	+ 10% Уменьшение вреда
	Ударь врага и получи больше энергии.
	'''
helmvfs:
	'''
	Повреждения от дальних выстрелов со временем увеличиваются
	Увеличить скорость пули дальнего действия
	'''
helmvfl:
	'''
	+ 15% Скорость движения
	+ 135 Максимальное потенциальное значение
	Скрытые атаки получают больше энергии.
	'''
helmvfe:
	'''
	+ 7 Колонка вызова
	+ 80% Вызвать вред
	Вызовите пустого симбиоза на помощь в бою.
	'''
