	DivineIntervention: {
		DisplayName: Священное вмешательство
		Tooltip:
			'''
			Запустить священный щит.
			Пулеметная завеса с обратным контактом
			Ущерб раненному врагу.
			Время охлаждения 3 минуты.
			'''
