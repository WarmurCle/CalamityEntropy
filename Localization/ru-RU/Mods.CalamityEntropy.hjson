  vfb:
    '''
    Бонус комплекта:
    +20 к пробитию защиты
    Попадание по цели увеличивает энергию Пустоты
    Даёт бонусы к скорости передвижения и полёта в зависимости от количества энергии Пустоты
    Нажмите клавишу бонуса брони, чтобы активировать энергию Пустоты: призовите Призрака Пустоты, чтобы он помогал в бою, и получите возможность летать бесконечно в течение 10 секунд.
    Тип урона Призрака Пустоты зависит от оружия, находящегося в руках
    '''
  helmvfc:
    '''
    -25% стоимости маны
    Попадания магических снарядов по врагам уменьшают эффект Маназависимости на 0.5 секунды
    '''
  helmvfd:
    '''
    +24% к скорости атаки
    +10% к снижению получаемого урона
    При попадании по целям накапливается больше энергии Пустоты.
    '''
