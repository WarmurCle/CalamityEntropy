	ShadeCloak: {
		DisplayName: Теневой плащ
		Tooltip:
			'''
			Чтобы вы не пострадали от контакта с противником или попадания занавески во время спринта, и увеличить расстояние спринта
			Для этого требуется три секунды охлаждения.
			Оборудование на панели моды обеспечивает только визуальные эффекты
			Плащ, созданный из пустоты, позволяет пользователю временно проникнуть в пустоту и пройти через все.
			'''
	}

