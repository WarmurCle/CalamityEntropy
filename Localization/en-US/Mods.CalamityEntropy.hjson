ModNameOverride: Calamity Entropy

Items: {
	VoidBlade: {
		DisplayName: Void Blade
		Tooltip: Perform broad, fast slashes in quick succession that inflicts [cebuff:CalamityEntropy/VoidTouch]
	}

	Weapons: {
		Rogue: {
			Revelation: {
				DisplayName: Revelation
				Tooltip:
					'''
					Throws a returning sickle that leaves behind mini meld-sickles
					Mini meld-sickles have a short lifespan and home in on targets
					Stealth strikes throw out a fan of 3 explosive homing sickles alongside a powerful slash
					'''
			}

			Silence: {
				DisplayName: Silence
				Tooltip:
					'''
					Throws a voidforged chakram that pulls itself toward the nearest enemy
					Stealth strikes unleash a spinning void disk that shreds enemies for 3 seconds
					Inflicts [cebuff:CalamityEntropy/VoidTouch]
					'''
			}

			ShadewindLance: {
				DisplayName: Shadewind Lance
				Tooltip:
					'''
					Throws a void-infused javelin that creates a small burst on impact
					Stealth strikes pierce, deal increased damage and create a larger burst on impact
					Inflicts [cebuff:CalamityEntropy/VoidTouch]
					'''
			}

			Aquashard: {
				DisplayName: Aquashard
				Tooltip:
					'''
					Throws a fragile javelin that shatters into smaller homing crystals upon hit
					Stealth strikes pierce, shed homing crystals as they fly, and cause the javelin to fracture on impact
					'''
			}

			SpearOfRadiance: {
				DisplayName: Spear of Radiance
				Tooltip:
					'''
					Throws a blessed javelin
					Stealth strikes release a spinning holy light
					'''
			}

			AbyssalPiercer: {
				DisplayName: Abyssal Piercer
				Tooltip:
					'''
					Throws a drowned javelin that erupts into homing abyssal water on impact and inflicts [cbuff:CalamityMod/CrushDepth]
					Stealth strikes unleash grasping tentacles that pierce enemies
					'''
			}

			AzureOfFirmament: {
				DisplayName: Azure of Firmament
				Tooltip:
					'''
					Throws a light-infused javelin
					Stealth strikes create a burst of homing feathers
					'''
			}

			ArbitratorII: {
				DisplayName: Arbitrator II
				Tooltip:
					'''
					Throws an exploding javelin
					Stealth strikes cause the javelin to lodge into struck targets before making a larger explosion
					'''
			}

			Voidseeker: {
				DisplayName: Voidseeker
				Tooltip:
					'''
					Swings a void-touched scythe
					Stealth strikes teleport you to your cursor and release a damaging shockwave
					'''
			}

			TheBeginingAndTheEnd: {
				DisplayName: The Beginning And The End
				Tooltip:
					'''
					Left click throws The Beginning, right click throws The End, both inflict the [cebuff:CalamityEntropy/LifeOppress] debuff
					The Beginning inflicts the [cebuff:CalamityEntropy/EclipsedImprint] debuff
					The End inflicts the [cebuff:CalamityEntropy/StareOfTheAbyss] debuff
					These debuffs both stack up to 8 times, when the opposite debuff is applied, that amount of Eclipse or Echo souls are created
					Eclipsed Souls return to you, restoring 4 life each and briefly granting the [cebuff:CalamityEntropy/ServiceBuff] buff
					Echo Souls relentlessly assault enemies for a short time
					Stealth strikes add two homing knives and unleash a swarm of both souls on impact
					'''
			}

			AmethystFrisbee: {
				DisplayName: Amethyst Frisbee
				Tooltip:
					'''
					Alternates between piercing and bouncing throws
					Stealth strikes create a shockwave on impact and always bounce
					'''
			}

			ProphecyFlyingKnife: {
				DisplayName: Prophetic Daggers
				Tooltip:
					'''
					Flings several homing daggers that inflict [cebuff:CalamityEntropy/SoulDisorder]
					Stealth strikes throw a single knife that spawns 6 collapsing runes on impact
					'''
			}

			TheDeadCut: {
				Tooltip:
					'''
					Swings a decaying scythe that restores stealth on hit
					Stealth strikes unleash a momentous slice
					'''
				DisplayName: The Dead Cut
			}

			LunarPlank: {
				DisplayName: Lunar Plank
				Tooltip:
					'''
					Throws a lunar plank to strike enemies 
					Stealth strikes create a pulse and release homing stars on impact
					'''
			}

			AzafureSurgeRod: {
				DisplayName: Azafure Surge Rod
				Tooltip:
					'''
					Throws a blade that lodges itself into enemies and bursts after a short delay
					The blade inflicts [cebuff:CalamityEntropy/MechanicalTrauma] and bursts after a short time
					Stealth strikes send out numerous homing blades that additionally inflict [cbuff:CalamityMod/GalvanicCorrosion] on burst
					'''
			}

			TlipocasScythe: {
				DisplayName: Tlipoca's Scythe
				Tooltip: NOT IMPLEMENTED AT THIS STAGE
			}

			AzafureLightMachineGun: {
				DisplayName: Azafure Light Machine Gun
				Tooltip:
					'''
					Fires a continuous laser that restores stealth on hit
					Stealth strikes fire a high damage grenade
					Both inflict the [cebuff:CalamityEntropy/MechanicalTrauma] debuff
					'''
			}

			AzafureAirReaper: {
				DisplayName: Azafure Air Reaper
				Tooltip:
					'''
					Throws a sickle that embeds itself into enemies and inficts [cebuff:CalamityEntropy/MechanicalTrauma]
					Stealth strikes throw a sickle that repeatedly tracks and slices the target
					'''
			}

			CrystalSpike: {
				DisplayName: Crystal Spike
				Tooltip:
					'''
					Throws vile crystals that embed themselves into enemies
					Stealth strikes rip the embedded crystals out of the enemy before rapidly throwing them
					'''
			}

			ScorchingChakram: {
				DisplayName: Scorching Chakram
				Tooltip:
					'''
					Throws a chakram that pierces and explodes into shards in midair
					Chakrams inflict [cbuff:OnFire] on impact
					Stealth strikes let the chakram release fireballs before homing in on enemies
					'''
			}

			EmberSpike: {
				DisplayName: Ember Spike
				Tooltip:
					'''
					Throws hot embers that melt into targets and explode on hit
					Stealth strikes rip the embedded embers out of the enemy enemy before rapidly throwing them
					Stealth strike hits create homing tectonic shards on hit
					Ignores 8 points of defense
					'''
			}
		}
	}

	PrisonOfPermafrost: {
		DisplayName: Prison of Permafrost
		Tooltip:
			'''
			Create a blizzard of frost and ice
			Hits inflict [cbuff:Frostburn] and grant the user [cbuff:CalamityMod/CosmicFreeze], increasing life regeneration and freezing nearby enemies
			Occasionally shoots large ice shards that inflict [cbuff:CalamityMod/MarkedforDeath]
			'''
	}

	Kinanition: {
		DisplayName: Kinanition
		Tooltip:
			'''
			[c/ce97fa:Launches a series of homing lightning arrows]
			[c/ce97fa:These arrows retain the original effect of your ammunition]
			[c/0078b9:Right click to launch a homing Thunderbolt that bursts into lightning on hit]
			'''
	}

	VoidRelics: {
		DisplayName: Void Relics
		Tooltip:
			'''
			Spawns a Void Mark that follows your cursor and inflicts [cebuff:CalamityEntropy/VoidTouch]
			The mark uses all of your summon slots, scaling with each one used
			Using the item with a Void Mark present will cause it to realease a bigger slash on any enemies inside
			The bigger slash deals double damage and inflicts [cebuff:CalamityMod/MarkedforDeath]
			'''
	}

	AuricToilet: {
		DisplayName: Auric Toilet
		Tooltip:
			'''
			Yharim's favorite place of respite. Sitting on such a revered object would be an egregious offense to all of Terraria. Too bad there's nothing stopping you...
			'You've made it. Need you go any farther?'
			'''
	}

	LotteryBox: {
		DisplayName: Lottery Terminal
		Tooltip:
			'''
			Spawns a personal gambling terminal
			Hold a coin in your inventory and click on it for a chance to win!
			'You've tried your luck in much more fatal ways thus far, what's a few coins for a good time?'
			'''
	}

	ToyRock: {
		DisplayName: Toy Rock
		Tooltip:
			'''
			Summons Wyrm-chan
			"She's still young"
			'''
	}

	YharimsStimulants: {
		DisplayName: Yharim's Stimulants
		Tooltip:
			'''
			5% increased damage
			4% increased critical strike chance
			10% increased melee speed
			Increases the knockback of your minions
			12% increased acceleration
			30% increased movement speed
			Greatly increases the Luck of the user
			+8 defense
			Provides +1HP/s life regeneration
			3% decreased mining speed
			'''
	}

	VoidBottle: {
		DisplayName: Void Ampule
		Tooltip:
			'''
			Summons the Cruiser
			Not consumable
			'''
	}

	VoidMonument: {
		DisplayName: Void Monument
		Tooltip: ""
	}

	Lore: {
		CruiserLore: {
			DisplayName: Cruiser
			Tooltip: ""
			Lore: "{$loreCruiser}"
		}

		NihilityTwinLore: {
			DisplayName: Nihility Twin
			Tooltip: ""
			Lore: "{$loreNihTwin}"
		}

		ProphetLore: {
			DisplayName: Prophet
			Tooltip: ""
			Lore: "{$loreProphet}"
		}

		LuminarisLore: {
			DisplayName: Luminaris
			Tooltip: ""
			Lore: "{$loreLuminaris}"
		}

		LoreApsychos: {
			DisplayName: Apsychos
			Tooltip: ""
			Lore: This ancient abomination was one of the first attempts at sealing away a god. At first, they tried to seal its essence within the tectonic plates deep in the world. This triggered the agitation of a dormant creature within the deepest lava oceans of the Underworld, causing it to lash out in an attempt to resist the sudden surge of energy. Ultimately, the attempt only half-succeded, leaving the strange creature stuck in its harrowing state. About time someone freed it of man's error.
		}
	}

	BrokenChainsaw: {
		DisplayName: Broken Chainsaw
		Tooltip: After a while this weapon overheats, disabling its use for a bit
	}

	MechanicalChainsaw: {
		DisplayName: Mechanical Chainsaw
		Tooltip: After a while this weapon overheats, disabling its use for a bit
	}

	EnslavedStar: {
		DisplayName: Enslaved Star
		Tooltip: Inflicts [cbuff:CalamityMod/Plague] and occasionally releases homing plague bees
	}

	Euangelion: {
		DisplayName: Euangelion
		Tooltip: Inflicts [cbuff:CalamityMod/Nightwither] and occasionally releases homing balls of light
	}

	Pioneer: {
		DisplayName: Pioneer
		Tooltip: Carves out rifts of void from the end of the chainsaw
	}

	GodsSnack: {
		DisplayName: Divine Delight
		Tooltip: Summons DoG-Chan
	}

	CruiserBag: {
		DisplayName: Treasure Bag (Cruiser)
		Tooltip: ""
	}

	CruiserRelic: {
		DisplayName: Cruiser Relic
		Tooltip: ""
	}

	DivineRemnants: {
		DisplayName: Divine Remnants
		Tooltip: Summons an astral friend to guide your way
	}

	BottleDarkMatter: {
		DisplayName: Contained Dark Matter
		Tooltip: Summons Ceaseless-Void-Chan
	}

	DivineIntervention: {
		DisplayName: Divine Intervention
		Tooltip:
			'''
			Sends out a divine shield that reflects projectiles
			You can send a shield out every 5 minutes
			'''
	}

	Godhead: {
		DisplayName: Godhead
		Tooltip: Projectiles are surrounded with a damaging aura that ignores i-frames and scales with the weapon's damage
	}

	VoidEcho: {
		DisplayName: Symbol of Theocracy
		Tooltip:
			'''
			Summons a circle of up to 6 divine cannons that fire lasers upon release
			Inflicts [cebuff:CalamityEntropy/VoidTouch]
			'Void is an ever potent element, only a few drops are needed for complete annihilation'
			'''
	}

	FriendBox: {
		DisplayName: Friend Box
		Tooltip:
			'''
			Summons a pair of orbiting twins that clone your projectiles
			Duplicated projectiles deal 100% damage of the original weapon
			Each pair of twins take 4 summon slots
			'''
	}

	LightningPendant: {
		DisplayName: Lightning Pendant
		Tooltip: Summons Storm Weaver-Chan
	}

	EvilFriend: {
		DisplayName: Evil Plush
		Tooltip: Summons a brimstone spirit that unleashes lasers
	}

	TheocracyPearlToy: {
		DisplayName: Theocracy Pearl Toy
		Tooltip: Summons Cruiser-Chan
	}

	CruiserTrophy: {
		DisplayName: Cruiser Trophy
		Tooltip: ""
	}

	VoidMonolith: {
		DisplayName: Void Monolith
		Tooltip: "'The moon lord's darkness holds no candle to this'"
	}

	VoidToy: {
		DisplayName: Void Toy
		Tooltip: Summons a cruiserling void pal
	}

	WingsOfHush: {
		DisplayName: Hush
		Tooltip:
			'''
			Shoots a piercing void arrow with two homing void clouds
			Inflicts [cebuff:CalamityEntropy/VoidTouch]
			'''
	}

	SoyMilk: {
		DisplayName: Soy Milk
		Tooltip:
			'''
			Multiplies attack speed by 3
			Divides damage dealt by 3
			Disables stealth gain while the buff is active
			'''
	}

	DarkArts: {
		DisplayName: Dark Arts
		Tooltip:
			'''
			Inflicts you with [cebuff:CalamityEntropy/StealthState], which gives complete immunity and marks all enemies and projectiles you touch
			Damages all marked entities and clears all marked projectiles after the effect wears off
			'''
	}

	VenomPiece: {
		DisplayName: Venom Piece
		Tooltip: Summons a melon cat
	}

	WisdomCard: {
		DisplayName: Oracle Card 『Wisdom』
		Tooltip:
			'''
			[COST]% decreased mana cost
			'Victory follows those in pursuit of facts'
			'''
	}

	TemperanceCard: {
		DisplayName: Oracle Card 『Temperance』
		Tooltip:
			'''
			Increases your max number of minions by [T]
			'Restrain your desire to gain the loyalty of legions'
			'''
	}

	RadianceCard: {
		DisplayName: Oracle Card 『Radiance』
		Tooltip:
			'''
			[LR]% increased life regeneration speed
			'Ensure you be one's light to mend the soul'
			'''
	}

	OracleDeck: {
		DisplayName: Oracle Deck
		Tooltip:
			'''
			[CR]% increased critical strike chance
			15% increased movement speed
			+[HP] max life
			+[ST] max stealth
			-30% mana cost
			Reduces damage taken by 5%
			Increases armor penetration by [AP]
			Increases your max number of minions by [MN]
			[ATS]% increased attack speed
			Light sources you emit are much brighter
			Nearby players are healed by 20HP over 5 seconds
			You will take at most half of your maximum health in damage
			'''
	}

	MetropolisCard: {
		DisplayName: Oracle Card 『Metropolis』
		Tooltip:
			'''
			+10 max stealth
			'Sleight shall be found in deep and darker places'
			'''
	}

	InspirationCard: {
		DisplayName: Oracle Card 『Inspiration』
		Tooltip:
			'''
			20% increased movement speed
			'Epiphany shall strike you as swiftly as the wind'
			'''
	}

	EntityCard: {
		DisplayName: Oracle Card 『Entity』
		Tooltip:
			'''
			10% increased attack speed
			'Adrenaline leaves fleshy kind as swift as the shadows'
			'''
	}

	EnduranceCard: {
		DisplayName: Oracle Card 『Endurance』
		Tooltip:
			'''
			Reduces damage taken by 5%
			'Steel tempered with such will shall hold up the mountains'
			'''
	}

	BrillianceCard: {
		DisplayName: Oracle Card 『Brilliance』
		Tooltip:
			'''
			Light sources you emit are brighter
			'In a world bathed in darkness, you must bring eternal light'
			'''
	}

	AuraCard: {
		DisplayName: Oracle Card 『Aura』
		Tooltip:
			'''
			+5% increased critical strike chance
			'A flash of insight is all that's needed for a fatal strike'
			'''
	}

	ThreadOfFate: {
		DisplayName: Thread of Fate
		Tooltip:
			'''
			Intertwines the mystic cards of the Oracle Deck
			Hold SHIFT to read the thread...
			'''
		HoldShiftForDetails:
			'''
			[i:CalamityEntropy/AuraCard]Aura Card: Scattered across hidden cabins and submerged crates...
			[i:CalamityEntropy/BrillianceCard]Brilliance: Sold by an eccentric, mysterious merchant...
			[i:CalamityEntropy/EntityCard]Entity: Offered to a pearly psychic of the sunken sea...
			[i:CalamityEntropy/InspirationCard]Inspiration: Left to rot in the sifting sands...
			[i:CalamityEntropy/MetropolisCard]Metropolics: Scribed from many common books...
			[i:CalamityEntropy/WisdomCard]Wisdom: Held by the dungeon's accursed warden...
			[i:CalamityEntropy/RadianceCard]Radiance: Requires the magic of a hallowed orb...
			[i:CalamityEntropy/TemperanceCard]Temperance: Used as a spiritual anchor for a mechanical monstrosity...
			[i:CalamityEntropy/EnduranceCard]Endurance: Tested in the part of the sea the light shall never touch...
			'''
	}

	RuneSong: {
		DisplayName: Archaic Song
		Tooltip:
			'''
			Releases two homing runes on swing that inflicts [cebuff:CalamityEntropy/SoulDisorder]
			Creates a ritual circle every five swings that release additional homing runes
			'''
	}

	GalaxyGrapeSoda: {
		DisplayName: Galaxy Grape Soda
		Tooltip:
			'''
			A blend of fresh grapes, godly essence, and...crimliate guardians?
			Turns you into a true Devourer of Gods
			'''
	}

	VoidAnnihilate: {
		DisplayName: Nihil Orbit
		Tooltip:
			'''
			Throws out up to 3 Nihil Runes that fire at enemies for a short time and inflict [cebuff:CalamityEntropy/VoidTouch]
			These runes can be teleported to by right clicking them
			Press [KEY] to retrieve all active runes
			'''
	}

	AuricBoulder: {
		DisplayName: Auric Boulder
		Tooltip: From the great creator Red-tropy
	}

	DustyStar: {
		DisplayName: Dusty Star
		Tooltip:
			'''
			Grants the appearance of the head developer
			Don't forget to leave a like!
			'''
	}

	SoulCandle: {
		DisplayName: Soul Candle
		Tooltip:
			'''
			Summons Signus-Chan
			'The finer the blade, the sharper the edge...'
			'''
	}

	KosRunePendant: {
		DisplayName: Kos Rune Pendant
		Tooltip: Summons Devourer-Chan and his chibi servants
	}

	OdinsRefuge: {
		DisplayName: Odin's Refuge
		Tooltip:
			'''
			Allows the ability to ram dash, empowered by the cosmic inferno
			This dash can slam through enemies without taking damage
			Grants immunity to knockback and fire blocks
			Grants immunity to the vast majority of debuffs, including God Slayer Inferno
			Causes stars to fall and increases length of invincibility after taking damage
			Grants bonus invincibility frames based on your missing health
			This effect scales from 10 frames while at full HP to 40 frames while at 25% or less HP
			Being struck for over 200 damage grants 30 additional invincibility frames
			Puts a shell around the owner when below 50% life that reduces damage taken
			Absorbs 25% of damage done to players on your team while above 25% life
			Provide you with a Holy Shield that can withstand damage once with a 150sec cooldown
			Hold shift and right click to toggle [i:PanicNecklace] [c/aaaaaa:Panic Necklace's effect]
			[TOGGLE]
			'''
		ToggleEffectOn: "[c/00ff00:Panic enabled]"
		ToggleEffectOff: "[c/808080:Panic disabled]"
	}

	VoidBar: {
		DisplayName: Void Bar
		Tooltip: Thousands of miles of cosmic entropy, condensed into this mere shell...
	}

	VoidOre: {
		DisplayName: Void Ore
		Tooltip: Caught in a constant state of dissolution and reformation...
	}

	VoidScales: {
		DisplayName: Void Scales
		Tooltip: A biological catalyst capable of stabilizing raw void...
	}

	HolyMoonlight: {
		DisplayName: Revered Moonlight
		Tooltip:
			'''
			+15% increased magic damage
			Forms a magic shield every thirty seconds that deals damage on contact, increases your movement speed and reduces mana consumption by 10%
			When the magic shield is broken, these benefits dissappear, but your magic damage can lifesteal
			This shield does not stack with the Chalice of the Blood God
			'''
	}

	PhantomPlanetKillerEngine: {
		DisplayName: Planet Killer Engine
		Tooltip:
			'''
			Summon a tiny warship to shoot rockets and bullets at your enemies
			Warships will use bullets from your inventory, but will not consume them
			These ships launch a laser every 8 rounds of bullets that inflicts [cebuff:CalamityEntropy/VoidTouch]
			'''
	}

	PowerOfTyrant: {
		DisplayName: Power of Tyrant
		Tooltip:
			'''
			Generates terra shockwaves on swing
			Landing true melee hits will charge the blade
			Charging the blade enough will summon a phantom of the tyrant that mimicks your swings
			Not landing true melee hits will reduce your charge and eventually unsummon the phantom
			'''
	}

