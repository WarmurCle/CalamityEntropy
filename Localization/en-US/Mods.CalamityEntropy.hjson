	DevouringCard: {
		DisplayName: Soul Card - Soul Rend
		Tooltip:
			'''
			Attacks ignore [1]% of enemy defense
			'The starving souls of one's sins gnaw at their will...'
			'''
	}

	CursedThread: {
		DisplayName: Cursed Thread
		Tooltip:
			'''
			Used to intertwine the Soul Deck
			The following materials are required:
			Requiem: Notes from spirits released after the death of Plantera...
			Whisper: Echoes of snips and snaps in the pinnacle of symbiosis...
			Purification: Found in living chests infused with hallowed energy...
			Obscure: Sunken in the fluids of dead gods...
			Grudge: Extracted from a dozen spirits' ectoplasm using a transmutative liquid...
			Indigo: Hidden in lakes upheld by the clouds...
			Mourning: A moral code of the protector of a lost jungle civilization...
			Woe: Fuels the beasts of a land ever so blighted...
			Soulrend: Found eating at the hallowed plating of a dungeon defender...
			'''
		HoldShiftForDetails: ""
	}

	SoulDeck: {
		DisplayName: Soul Deck
		Tooltip:
			'''
			Reduces most cooldowns by [CD]%
			Increases immunity time on hit by [IM]%
			Shortens debuff durations by [DB]%
			Enemy contact greatly increases health regen, restores flight time and inflicts [cebuff:CalamityEntropy/SoulDisorder]
			Hitting enemies may release souls that fly to you, healing 2 life with 1 additional life for every 160 maximum life, restoring 10 mana and granting 6 temporary defense
			Increases flight speed by [FL]% and duration by [FT]%
			Slows the rate of decline when defense, damage, critical strike chance, damage reduction or life regeneration decrease
			The higher your health, the higher your damage (up to [BD]%)
			The lower your health, the higher your damage reduction (up to [BE]%)
			Attacks ignore [AP]% of enemy defense
			'''
	}

